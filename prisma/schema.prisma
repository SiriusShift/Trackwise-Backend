generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  Pending
  Completed
  Overdue
  Cancelled
  Failed
}

enum Type {
  Expense
  Income
  Transfer
}

enum NotificationType {
  Reminder
  System
  General
  Warning
  Info
  Success
  Error
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum RecurringBehaviour {
  AUTO_LOG
  REMIND
}

enum RecurringLogResult {
  CREATED
  REMINDED
  SKIPPED
  FAILED
}

model User {
  id              Int     @id @default(autoincrement())
  firstName       String? @map("first_name")
  lastName        String? @map("last_name")
  email           String  @unique
  username        String? @unique
  password        String? @map("password")
  role            String  @default("user")
  phoneNumber     String? @map("phone_number")
  profileImageUrl String? @map("profile_image_url")
  isActive        Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt
  google_id String?  @unique

  assets            Asset[]
  expenses          Expense[]
  incomes           Income[]
  transfers         Transfer[]
  categories        Categories[]
  categoriesTracker CategoryTracker[]
  recurring         RecurringTransaction[]
  settings          Settings?
  notifications     Notification[]
  resetTokens       ResetToken[]
}

model Asset {
  id          Int      @id @default(autoincrement())
  name        String
  balance     Decimal
  type        String   @default("bank") // bank | cash | ewallet | credit
  currency    String   @default("PHP")
  creditLimit Decimal?
  color       String?
  icon        String?
  userId      Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  expenses Expense[]
  incomes  Income[]

  sentTransfers     Transfer[] @relation("FromAsset")
  receivedTransfers Transfer[] @relation("ToAsset")

  recurringTransactionFrom RecurringTransaction[] @relation("RecurringTransferFrom")
  recurringTransactionTo   RecurringTransaction[] @relation("RecurringTransferTo")

  @@index([userId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  amount      Decimal
  image       String?
  status      Status?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId        Int
  categoryId    Int
  assetId       Int?
  recurringId   Int?
  installmentId Int?
    recurringDueDate DateTime?

  user              User                  @relation(fields: [userId], references: [id])
  category          Categories            @relation(fields: [categoryId], references: [id])
  asset             Asset?                @relation(fields: [assetId], references: [id])
  recurringTemplate RecurringTransaction? @relation("RecurringExpenses", fields: [recurringId], references: [id])

  @@index([userId])
  @@index([recurringId])
}

model Income {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  description String?
  amount      Decimal
  image       String?
  status      Status?  @default(Pending)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      Int
  categoryId  Int
  assetId     Int?
  recurringId Int?

  user              User                  @relation(fields: [userId], references: [id])
  category          Categories            @relation(fields: [categoryId], references: [id])
  asset             Asset?                @relation(fields: [assetId], references: [id])
  recurringTemplate RecurringTransaction? @relation("RecurringIncomes", fields: [recurringId], references: [id])

  @@index([userId])
  @@index([recurringId])
}

model Transfer {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  description String?
  amount      Decimal
  image       String?
  status      Status   @default(Pending)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      Int
  categoryId  Int
  fromAssetId Int
  toAssetId   Int?
  recurringId Int?

  user              User                  @relation(fields: [userId], references: [id])
  category          Categories            @relation(fields: [categoryId], references: [id])
  fromAsset         Asset                 @relation("FromAsset", fields: [fromAssetId], references: [id])
  toAsset           Asset?                @relation("ToAsset", fields: [toAssetId], references: [id])
  recurringTemplate RecurringTransaction? @relation("RecurringTransfers", fields: [recurringId], references: [id])

  @@index([userId])
  @@index([recurringId])
}

model RecurringTransaction {
  id              Int                @id @default(autoincrement())
  type            Type
  description     String
  amount          Decimal
  interval        Int
  unit            String // day | week | month | year
  behaviour       RecurringBehaviour
  status          RecurringStatus    @default(ACTIVE)
  startDate       DateTime
  nextDueDate     DateTime
  endDate         DateTime?
  lastTriggeredAt DateTime?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  userId      Int
  categoryId  Int
  fromAssetId Int? // Transfer: source account
  toAssetId   Int? // Transfer: destination account

  user      User       @relation(fields: [userId], references: [id])
  category  Categories @relation(fields: [categoryId], references: [id])
  fromAsset Asset?     @relation("RecurringTransferFrom", fields: [fromAssetId], references: [id])
  toAsset   Asset?     @relation("RecurringTransferTo", fields: [toAssetId], references: [id])

  generatedExpenses  Expense[]      @relation("RecurringExpenses")
  generatedIncomes   Income[]       @relation("RecurringIncomes")
  generatedTransfers Transfer[]     @relation("RecurringTransfers")
  logs               RecurringLog[]
  notifications      Notification[]

  @@index([userId])
  @@index([nextDueDate, status]) // cron query index
}

// Tracks every cron fire for a recurring schedule.
// Acts as audit trail and deduplication guard.
model RecurringLog {
  id           Int                @id @default(autoincrement())
  result       RecurringLogResult
  firedAt      DateTime // UTC timestamp the cron fired
  errorMessage String? // populated when result = FAILED
  createdAt    DateTime           @default(now())

  recurringId         Int
  generatedExpenseId  Int? // set when result = CREATED + type = Expense
  generatedIncomeId   Int? // set when result = CREATED + type = Income
  generatedTransferId Int? // set when result = CREATED + type = Transfer

  recurring RecurringTransaction @relation(fields: [recurringId], references: [id])

  @@unique([recurringId, firedAt]) // prevents duplicate fires on same schedule+date
  @@index([recurringId])
}

model Categories {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  icon      String   @default("default_icon")
  color     String   @default("#6B7280") // neutral gray as fallback
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int?

  user              User?                  @relation(fields: [userId], references: [id])
  expenses          Expense[]
  incomes           Income[]
  transfers         Transfer[]
  categoriesTracker CategoryTracker[]
  recurring         RecurringTransaction[]

  @@unique([userId, name, type])
}

model CategoryTracker {
  id       Int      @id @default(autoincrement())
  limit    Decimal?
  period   String   @default("monthly") // monthly | yearly
  isActive Boolean  @default(true)

  userId     Int
  categoryId Int

  user     User       @relation(fields: [userId], references: [id])
  category Categories @relation(fields: [categoryId], references: [id])

  @@index([userId])
}

model Settings {
  id                 Int                @id @default(autoincrement())
  timezone           String             @default("Asia/Manila")
  timeFormat         String             @default("hh:mm A")
  currency           String             @default("PHP")
  weekStartDay       Int                @default(0) // 0 = Sunday, 1 = Monday
  recurringBehaviour RecurringBehaviour @default(REMIND)
  emailNotification  Boolean            @default(false)
  mobileNotification Boolean            @default(false)
  notifyDays         Int                @default(1)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  userId Int @unique

  user User @relation(fields: [userId], references: [id])
}

model EmailVerification {
  id               Int      @id @default(autoincrement())
  email            String
  verificationCode String
  expirationTime   DateTime
  isVerified       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@map("email_verifications")
}

model ResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Notification {
  id      Int              @id @default(autoincrement())
  title   String
  message String
  type    NotificationType @default(General)

  isRead     Boolean @default(false)
  isArchived Boolean @default(false)

  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId      Int
  recurringId Int?

  user User @relation(fields: [userId], references: [id])

  recurring RecurringTransaction? @relation(fields: [recurringId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([recurringId])
}

